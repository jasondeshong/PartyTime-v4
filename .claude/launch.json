{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Vite Dev Server (Frontend)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173,
      "cwd": "client"
    },
    {
      "name": "Express + Socket.io (Backend)",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--watch", "src/index.js"],
      "port": 3001,
      "cwd": "server"
    }
  ]
}
